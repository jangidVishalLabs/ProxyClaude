# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- runtime ---
NODE_ENV=development
PORT=3000

# --- postgres (docker-compose reads these too) ---
POSTGRES_USER=proxyclaude
POSTGRES_PASSWORD=proxyclaude
POSTGRES_DB=proxyclaude
POSTGRES_PORT=5432
DATABASE_URL=postgresql://proxyclaude:proxyclaude@localhost:5432/proxyclaude?schema=public

# --- auth (generate with: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- first admin (seed script, Phase 1) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password-min-12

# --- vps provisioner (Phase 4) ---
VPS_HOST=
VPS_SSH_PORT=22
VPS_PROVISIONER_USER=
VPS_PROVISIONER_KEY_PATH=
